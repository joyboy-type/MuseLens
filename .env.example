# Local image library and SQLite/task state
MUSELENS_MODE=local
MUSELENS_IMAGE_DIR=/absolute/path/to/MuseLensLibrary
MUSELENS_STATE_DIR=/absolute/path/to/MuseLensLibrary/.muselens
MUSELENS_THUMBNAIL_DIR=/absolute/path/to/MuseLensLibrary/.muselens/thumbnails/v1

# Model and retrieval
MUSELENS_CLIP_MODEL=google/siglip2-base-patch16-224
MUSELENS_INDEX_BACKEND=numpy
MUSELENS_TOP_K=12
MUSELENS_SEARCH_MIN_SCORE=0.12
MUSELENS_SEARCH_RELATIVE_MARGIN=0.035
MUSELENS_IMAGE_SEARCH_RELATIVE_MARGIN=0.05

# Near-duplicate detection (64-bit pHash + normalized average color)
MUSELENS_DUPLICATE_HASH_DISTANCE=8
MUSELENS_DUPLICATE_COLOR_DISTANCE=45

# Optional local high-precision mode (install with: pip install -e '.[precision]')
# MUSELENS_RERANKER_MODEL=Qwen/Qwen3-VL-Reranker-2B
MUSELENS_RERANKER_MIN_SCORE=0.40
MUSELENS_RERANKER_RECALL_K=5
MUSELENS_RERANKER_RECALL_TEMPLATE=A photo of {query}.

# Upload and thumbnail safety limits
MUSELENS_MAX_UPLOAD_MB=12
MUSELENS_MAX_IMAGE_PIXELS=40000000
MUSELENS_MAX_BATCH_FILES=100
MUSELENS_MAX_JOB_FILES=500
MUSELENS_MAX_JOB_TOTAL_MB=512
MUSELENS_THUMBNAIL_MAX_SIZE=640
MUSELENS_THUMBNAIL_QUALITY=82

# Optional when the frontend and API are hosted on different origins
MUSELENS_CORS_ORIGINS=http://localhost:5173

# Public demo only: immutable seed copied into ephemeral runtime storage on boot
# MUSELENS_DEMO_SEED_DIR=/app/demo_assets
MUSELENS_TEMP_GALLERY_MAX_FILES=30
MUSELENS_TEMP_GALLERY_MAX_UPLOAD_MB=8
MUSELENS_TEMP_GALLERY_MAX_TOTAL_MB=120
MUSELENS_TEMP_GALLERY_TTL_SECONDS=1800
MUSELENS_TEMP_GALLERY_MAX_SESSIONS=8
MUSELENS_TEMP_GALLERY_SEARCH_RELATIVE_MARGIN=0.035
